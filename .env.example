# ============================================================
# .env.example  —  copy to .env and fill in your values
# ============================================================

# Eventbrite API key (get at https://www.eventbrite.com/platform/api)
EVENTBRITE_API_KEY=your_eventbrite_key_here

# Bandsintown — любий рядок-ідентифікатор вашого застосунку
BANDSINTOWN_APP_ID=openclaw_events

# Scraping
REQUEST_TIMEOUT=20
REQUEST_RETRIES=3
REQUEST_DELAY=1.5

# Storage: sqlite | json
STORAGE_BACKEND=sqlite
SQLITE_PATH=events.db
JSON_PATH=events.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=scraper.log

# Telegram (для розсилки нових подій через OpenClaw Bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
